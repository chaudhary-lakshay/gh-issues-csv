{
  "manifest_version": 3,
  "name": "GitHub Issues to CSV",
  "version": "1.0.0",
  "description": "Export the currently filtered GitHub issue or pull request list to an Excel-ready CSV file.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Export these GitHub issues to CSV",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": ["https://api.github.com/*"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["csv.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
